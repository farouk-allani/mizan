# MIZAN secrets — copy to .env and fill. NEVER commit .env.
# Load with: set -a && source .env && set +a   (or use systemd EnvironmentFile)

# --- Trust Wallet Agent Kit (portal.trustwallet.com → dashboard/apps) ---
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=
# Wallet password used by `twak wallet create`. Resolution order inside twak:
# --password flag (NEVER use) → TWAK_WALLET_PASSWORD → OS keychain.
TWAK_WALLET_PASSWORD=

# --- CoinMarketCap (pro.coinmarketcap.com — free Basic tier is fine for dev) ---
# Only needed while data.cmcTransport=apikey. The x402 transport needs no key:
# the agent pays 0.01 USDC per call from its own wallet.
CMC_API_KEY=

# --- LLM (any OpenAI-compatible endpoint: OpenRouter, MiMo, ...) ---
LLM_API_KEY=

# --- Telegram monitoring (same pattern as the Hermes gateway) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
